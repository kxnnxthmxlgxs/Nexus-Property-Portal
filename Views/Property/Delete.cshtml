@model NexusPropertyPortal.Models.Property

@{
    ViewData["Title"] = "Confirm Delete";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="p-5 bg-white rounded-4 shadow-sm border border-danger border-opacity-25">
                <i class="bi bi-exclamation-triangle text-danger display-1"></i>
                <h2 class="mt-3">Are you sure?</h2>
                <p class="text-muted">You are about to delete the property in <strong>@Model.Suburb</strong>. This will remove it from the AI training dataset.</p>
                
                <hr class="my-4">
                
                <form asp-action="Delete">
                    <input type="hidden" asp-for="Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg shadow">Yes, Delete Property</button>
                        <a asp-action="Index" class="btn btn-light">No, Keep it</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>