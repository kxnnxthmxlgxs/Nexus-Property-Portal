@model IEnumerable<NexusPropertyPortal.Models.Property>
@inject NexusPropertyPortal.Services.PricePredictionService PredictionService


<h2>Property Inventory</h2>


<div class="row mb-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-primary text-white p-3">
            <h6 class="text-uppercase small">Total Listings</h6>
            <h2 class="fw-bold">@ViewBag.TotalProperties</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-dark text-white p-3">
            <h6 class="text-uppercase small">Portfolio Value</h6>
            <h2 class="fw-bold">@ViewBag.PortfolioValue.ToString("C0")</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm bg-light p-3">
            <h6 class="text-uppercase small text-muted">Avg. Property Size</h6>
            <h2 class="fw-bold text-primary">@ViewBag.AvgSqMeters.ToString("N0") m²</h2>
        </div>
    </div>
</div>


<div class="row mb-4">
    <div class="col-md-6">
        <form asp-action="Index" method="get" class="d-flex">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="searchString" class="form-control border-start-0"
                       placeholder="Filter by suburb (e.g. Woodstock)..." aria-label="Search">
                <button class="btn btn-primary px-4" type="submit">Filter</button>
                @if (!string.IsNullOrEmpty(Context.Request.Query["searchString"]))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </form>
    </div>
</div>

<p>
    <a asp-action="Create" class="btn btn-success">Add New Property</a>
</p>

<div class="table-responsive shadow-sm rounded-3">
    
    <table class="table table-hover align-middle custom-grid mb-0">
        <thead class="table-light">
            <tr>
                <th class="text-uppercase small fw-bold">Suburb</th>
                <th class="text-uppercase small fw-bold text-center">Beds</th>
                <th class="text-uppercase small fw-bold text-center">Baths</th>
                <th class="text-uppercase small fw-bold text-center">Size (m²)</th>
                <th class="text-uppercase small fw-bold text-center">Garage</th>
                <th class="text-uppercase small fw-bold">Asking Price</th>
                <th class="text-uppercase small fw-bold text-primary">AI Estimate</th>
                <th class="text-center text-uppercase small fw-bold">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-medium">@item.Suburb</td>
                    <td class="text-center">@item.Bedrooms</td>
                    <td class="text-center">@item.Bathrooms</td>
                    <td class="text-center">@item.SquareMeters</td>
                    <td class="text-center">@item.GarageCount</td>
                    <td>@item.Price.ToString("C")</td>
                    <td class="text-primary fw-bold">
                        @PredictionService.PredictPrice(item.Bedrooms, item.Bathrooms, item.SquareMeters, item.GarageCount).ToString("C")
                    </td>
                    <td class="text-center">
                        <div class="btn-group btn-group-sm">
                            <!-- Explicitly point to the Property Controller -->
                            <a asp-controller="Property" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-controller="Property" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a asp-controller="Property" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    </td>
                    <td>
                        @{
                            // No casting needed because both are now decimals
                            decimal estimate = PredictionService.PredictPrice(item.Bedrooms, item.Bathrooms, item.SquareMeters, item.GarageCount);
                            decimal difference = item.Price - estimate;
                        }
    
                        @if (difference <= 0)
                        {
                            <span class="badge bg-success shadow-sm">Good Value</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark shadow-sm">Above Market</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>